{
    "testmodule": {
        "prefix": "testmod",
        "body": [
            "#[cfg(test)]",
            "mod tests {",
            "    ${0}",
            "}"
        ]
    },
    "testcase": {
        "prefix": "testcase",
        "body": [
            "#[test]",
            "fn ${1}() {",
            "    ${0}",
            "}"
        ]
    },
    "display_impl": {
        "prefix": "display_impl",
        "body": [
            "impl Display for ${1} {",
            "    fn fmt(&self, formatter: &mut Formatter<'_>) -> std::fmt::Result {",
            "        write!(formatter, \"{}\", self.0)",
            "    }",
            "}"
        ]
    },
    "match": {
        "prefix": "match",
        "body": [
            "match $1 {",
            "    $0",
            "}"
        ]
    },
    "match_result": {
        "prefix": "matchr",
        "body": [
            "match $1 {",
            "   Ok($2) => {",
            "       $3",
            "   }",
            "   Err($4) => {",
            "       $5",
            "   }",
            "}"
        ]
    },
    "if_let": {
        "prefix": "iflet",
        "body": [
            "if let ${1:Some}($2) = $3 {",
            "    $4",
            "}"
        ]
    },
    "while_let": {
        "prefix": "whilelet",
        "body": [
            "while let ${1:Some}($2) = $3 {",
            "    $4",
            "}"
        ]
    },
    "typestate_pattern": {
        "prefix": "typestate",
        "body": [
            "struct $1<T> {",
            "    _phantom: PhantomData<T>,",
            "}",
            "",
            "struct $2;",
            "",
            "impl $1<$2> {",
            "",
            "}"
        ]
    }
}
