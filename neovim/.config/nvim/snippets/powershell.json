{
    "while": {
        "prefix": "while",
        "body": [
            "while (${1})",
            "{",
            "  ${2}",
            "}"
        ]
    },
    "try..catch": {
        "prefix": "try",
        "body": [
            "try",
            "{",
            "  ${1}",
            "} catch",
            "{",
            "  ${2}",
            "}"
        ]
    }
}
